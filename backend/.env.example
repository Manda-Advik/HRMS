# ─── Backend Environment Variables ────────────────────────────────────────────
# Copy to .env and fill in values

# Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# Supabase anon key (public, safe in backend)
SUPABASE_ANON_KEY=your_anon_key_here

# Supabase service role key (SECRET — never expose to client)
# Required for sending invite emails via inviteUserByEmail
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Your deployed frontend URL — used as redirectTo in invite emails
# Local dev: http://localhost:5173
# Production: https://your-app.vercel.app
SITE_URL=http://localhost:5173

# Allowed CORS origins (comma-separated, no spaces)
# Local dev: http://localhost:5173
# Production: https://your-app.vercel.app
ALLOWED_ORIGINS=http://localhost:5173

# Port
PORT=5000
